# Application secret — used to sign JWT session cookies
SECRET_KEY=change-me-to-a-long-random-string

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth 2.0
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Okta OAuth 2.0
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=your-tenant.okta.com

# GitHub OAuth 2.0
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
BASE_URL=http://localhost:8000
